{
  "executionRoleArn": "arn:aws:iam::259151462184:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "blacklist-container",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "3072",
  "family": "blacklist-app-task-definition"
}